# Copy to .env.local for local use. Never commit real credential values.
TC_CF_ACCOUNT_ID=
TC_CF_DATABASE_ID=
TC_CF_API_TOKEN=
# Operator-only credentials for public deployment and scheduler maintenance
TC_CF_PAGES_API_TOKEN=
TC_CF_WORKERS_API_TOKEN=
TC_GITHUB_DISPATCH_TOKEN=
TC_PERSIST=0
# Legacy one-shot scanner settings
TC_SCAN_PAGES=1
TC_SCAN_PAGE_DELAY_SECONDS=15
# Shared local/default cycle settings. Public Actions override their own Hot and Backfill budgets.
TC_FINALIZATION_AGE_HOURS=12
TC_HOT_LOOKBACK_MINUTES=240
TC_HOT_MAX_SECONDS=420
TC_CYCLE_MAX_SECONDS=1200
TC_REQUEST_INTERVAL_SECONDS=10
TC_DEEP_RESERVED_SECONDS=300
TC_BLOCK_COOLDOWN_HOURS=6
TC_TRANSIENT_FETCH_ATTEMPTS=2

# FMKorea-only local Google Chrome transport. Keep this profile separate from
# the Chrome profile used for personal browsing. Empty paths use safe defaults.
TC_FMKOREA_PROFILE_DIR=
TC_FMKOREA_CHROME_PATH=
TC_FMKOREA_CDP_PORT=39225
TC_FMKOREA_HEADLESS=0
TC_FMKOREA_STARTUP_TIMEOUT_SECONDS=15
TC_FMKOREA_REQUEST_INTERVAL_SECONDS=10
